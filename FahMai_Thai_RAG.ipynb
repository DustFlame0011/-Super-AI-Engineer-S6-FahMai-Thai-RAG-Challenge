      "source": [
        "from rank_bm25 import BM25Okapi\n",
        "\n",
        "# Tokenize all chunks\n",
        "tokenized_chunks = [word_tokenize(c[\"text\"], engine=\"newmm\") for c in chunks]\n",
        "bm25 = BM25Okapi(tokenized_chunks)\n",
