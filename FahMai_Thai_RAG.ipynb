        "# Re-embed new chunks after rebuilt chunks\n",
        "print(f\"Total chunks: {len(chunks)}\")\n",
        "\n",
        "chunk_texts = [c[\"text\"] for c in chunks]\n",
        "chunk_embeddings = embed_model.encode(\n",
        "    chunk_texts,\n",
        "    batch_size=64,\n",
        "    show_progress_bar=True,\n",
        "    normalize_embeddings=True\n",
        ")\n",
        "\n",
        "print(f\"Embeddings shape: {chunk_embeddings.shape}\")\n",
        "print(f\"chunks count: {len(chunks)}\")\n",
        "print(f\"Match: {len(chunks) == chunk_embeddings.shape[0]}\")  #True\n",
        "\n",
        "# Rebuild BM25 index\n",
        "from rank_bm25 import BM25Okapi\n",
        "from pythainlp.tokenize import word_tokenize\n",
        "\n",
        "tokenized_chunks = [word_tokenize(c[\"text\"], engine=\"newmm\") for c in chunks]\n",
        "bm25 = BM25Okapi(tokenized_chunks)\n",
        "print(f\"BM25 rebuilt over {len(tokenized_chunks)} chunks\")"
      ],
