        "def run_pipeline(questions, retrieve_fn, label=\"dense\", n=N_QUESTIONS):\n",
        "    \"\"\"Run retrieval + LLM on first n questions. Returns predictions dict.\"\"\"\n",
        "    predictions = {}\n",
        "    for i, q in enumerate(questions[:n]):\n",
        "        retrieved_chunks = retrieve_fn(q[\"question\"], q[\"choices\"])\n",
        "        prompt = build_rag_prompt(q[\"question\"], q[\"choices\"], retrieved_chunks)\n",
        "        raw = ask_llm([\n",
        "            {\"role\": \"system\", \"content\": SYSTEM_PROMPT},\n",
        "            {\"role\": \"user\", \"content\": prompt},\n",
        "        ])\n",
        "        pred = parse_answer(raw)\n",
        "        predictions[q[\"id\"]] = pred if pred else 9  # default 9 better than 1\n",
        "        print(f\"  Q{q['id']:>3}: pred={predictions[q['id']]} | raw={str(raw)[:30]}\")\n",
        "        time.sleep(0.3)\n",
        "    print(f\"\\n{label}: answered {len(predictions)} questions\")\n",
        "    return predictions\n",
        "\n",
        "# Dense retrieval function\n",
        "def dense_retrieve_chunks(query, choices=None):\n",
        "    expanded = build_query(query, choices) if choices else query\n",
        "    idx, _ = dense_retrieve(expanded, chunk_embeddings, k=TOP_K)\n",
        "    return [chunks[int(i)] for i in idx]\n",
        "\n",
        "dense_preds = run_pipeline(questions, dense_retrieve_chunks, label=\"dense\")"
      ]
    },
