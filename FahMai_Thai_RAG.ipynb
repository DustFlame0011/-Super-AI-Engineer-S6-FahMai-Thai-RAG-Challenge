        "from pathlib import Path\n",
        "\n",
        "KB_DIR = \"/content/data/data/knowledge_base\"\n",
        "DATA_DIR = \"/content/data/data\"\n",
        "\n",
        "kb_dir = Path(KB_DIR)\n",
        "documents = []\n",
        "for fp in sorted(kb_dir.rglob(\"*.md\")):\n",
