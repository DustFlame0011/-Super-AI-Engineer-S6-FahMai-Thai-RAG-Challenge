      "source": [
        "### 1.2 Chunking\n",
        "\n",
        "LLMs have limited context windows, and long documents dilute relevance. We split each document into smaller **chunks** using a fixed-size sliding window with overlap."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 92,
      "id": "26ox89ujjiv",
      "metadata": {
        "id": "26ox89ujjiv",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "2ab216d1-b8bd-4c25-9a7b-365ff759b3dd"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Created 1038 chunks from 118 documents\n",
            "\n",
            "--- Sample chunk ---\n",
            "[หมวด: policies | ไฟล์: cancellation_policy]\n",
            "# นโยบายการยกเลิกคำสั่งซื้อ — ร้านฟ้าใหม่\n",
            "\n",
            "**วันที่อัปเดต:** 1 มีนาคม 2569\n",
            "\n",
            "---\n"
          ]
        }
      ],
      "source": [
        "import re\n",
        "\n",
        "def chunk_by_markdown(text, source, max_size=800):\n",
        "    \"\"\"Split by markdown headers, add source metadata to each chunk\"\"\"\n",
        "    folder = source.split(\"/\")[0]  # products / policies / store_info\n",
        "    filename = source.replace(\".md\", \"\").split(\"/\")[-1]\n",
        "\n",
        "    chunks_out = []\n",
        "    sections = re.split(r'\\n(?=#+\\s)', text)\n",
        "\n",
        "    for section in sections:\n",
        "        if not section.strip():\n",
        "            continue\n",
        "\n",
        "        # Add metadata prefix for every chunk know where it's from\n",
        "        meta = f\"[หมวด: {folder} | ไฟล์: {filename}]\\n\"\n",
        "        enriched = meta + section.strip()\n",
        "\n",
        "        if len(enriched) <= max_size:\n",
        "            chunks_out.append({\"text\": enriched, \"source\": source})\n",
        "        else:\n",
        "            # Sub-split if too long\n",
        "            for i in range(0, len(section), max_size - 150):\n",
        "                part = section[i:i + max_size - 150].strip()\n",
        "                if part:\n",
        "                    chunks_out.append({\"text\": meta + part, \"source\": source})\n",
        "\n",
        "    return chunks_out\n",
        "\n",
        "# Build new chunks\n",
        "chunks = []\n",
        "for doc in documents:\n",
        "    for chunk in chunk_by_markdown(doc[\"text\"], doc[\"path\"]):\n",
        "        chunks.append(chunk)\n",
        "\n",
        "print(f\"Created {len(chunks)} chunks from {len(documents)} documents\")\n",
        "print(f\"\\n--- Sample chunk ---\")\n",
        "print(chunks[0][\"text\"][:400])"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Query Expansion + Majority Vote\n",
        "\n",
        "from collections import Counter\n",
        "\n",
        "# 1. Query expansion\n",
        "def build_query(question, choices):\n",
        "    \"\"\"รวม question + choices เพื่อ retrieve ให้แม่นขึ้น\"\"\"\n",
        "    relevant_choices = [v for k, v in choices.items() if int(k) <= 8]\n",
        "    choices_str = \" \".join(relevant_choices[:4])\n",
        "    return f\"{question} {choices_str}\"\n",
        "\n",
        "# 2. Majority vote function\n",
        "def ask_with_vote(messages):\n",
        "    \"\"\"ถามหลาย models แล้ว majority vote\"\"\"\n",
        "    models = [\"typhoon\", \"openthaigpt\"]\n",
        "    answers = []\n",
        "    for model in models:\n",
        "        raw = ask_llm(messages, model=model)\n",
        "        ans = parse_answer(raw) if raw else None\n",
        "        if ans:\n",
        "            answers.append(ans)\n",
        "    if not answers:\n",
        "        return 9\n",
        "    return Counter(answers).most_common(1)[0][0]\n",
        "\n",
        "# 3. Updated retrieve functions\n",
        "def dense_retrieve_chunks(query, choices=None):\n",
        "    expanded = build_query(query, choices) if choices else query\n",
        "    idx, _ = dense_retrieve(expanded, chunk_embeddings, k=TOP_K)\n",
        "    return [chunks[int(i)] for i in idx]\n",
        "\n",
        "# 4. Updated run_pipeline use ask_with_vote rather than ask_llm\n",
        "def run_pipeline(questions, retrieve_fn, label=\"hybrid\", n=N_QUESTIONS):\n",
        "    predictions = {}\n",
        "    for i, q in enumerate(questions[:n]):\n",
        "        retrieved_chunks = retrieve_fn(q[\"question\"], q[\"choices\"])\n",
        "        prompt = build_rag_prompt(q[\"question\"], q[\"choices\"], retrieved_chunks)\n",
        "        messages = [\n",
        "            {\"role\": \"system\", \"content\": SYSTEM_PROMPT},\n",
        "            {\"role\": \"user\", \"content\": prompt},\n",
        "        ]\n",
        "        pred = ask_with_vote(messages)\n",
        "        predictions[q[\"id\"]] = pred\n",
        "        print(f\"  Q{q['id']:>3}: pred={pred}\")\n",
        "        time.sleep(0.3)\n",
        "    print(f\"\\n{label}: answered {len(predictions)} questions\")\n",
        "    return predictions\n",
        "\n",
        "print(\"✅ Functions defined: build_query, ask_with_vote, run_pipeline\")\n",
        "print(\"   จะใช้ models: typhoon + openthaigpt (majority vote)\")"
      ],
